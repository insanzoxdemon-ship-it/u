{
  "functions": {
    "api/db-server.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/login.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/db-server(.*)",
      "dest": "/api/db-server"
    },
    {
      "src": "/api/login",
      "dest": "/api/login"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
